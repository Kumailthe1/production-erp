    "components": {
        "schemas": {
            "ErrorResponse": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": false
                    },
                    "message": {
                        "type": "string",
                        "example": "Validation failed."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "schema": "OpenApi",
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "type": "object"
            },
            "OpenApi": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            },
            "LoginRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@amsal.test"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "SecurePass123"
                    }
                },
                "type": "object"
            },
            "ProductionSettingRequest": {
                "required": [
                    "name",
                    "parameter_kind",
                    "quantity_unit"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Milk"
                    },
                    "code": {
                        "type": "string",
                        "example": "milk"
                    },
                    "parameter_kind": {
                        "type": "string",
                        "enum": [
                            "input",
                            "packaging",
                            "config",
                            "output"
                        ],
                        "example": "input"
                    },
                    "quantity_unit": {
                        "type": "string",
                        "example": "kg"
                    },
                    "unit_cost": {
                        "type": "number",
                        "format": "float",
                        "example": 850
                    },
                    "default_quantity": {
                        "type": "number",
                        "format": "float",
                        "example": 12
                    },
                    "notes": {
                        "type": "string",
                        "example": "Fresh cow milk cost per kg"
                    },
                    "sort_order": {
                        "type": "integer",
                        "example": 10
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "ProductionBatchItemRequest": {
                "required": [
                    "parameter_id"
                ],
                "properties": {
                    "parameter_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "new_quantity_added": {
                        "type": "number",
                        "format": "float",
                        "example": 12
                    },
                    "closing_leftover_quantity": {
                        "type": "number",
                        "format": "float",
                        "example": 1.5
                    },
                    "notes": {
                        "type": "string",
                        "example": "1.5kg milk remained after processing"
                    }
                },
                "type": "object"
            },
            "ProductionBatchRequest": {
                "required": [
                    "batch_number",
                    "production_date",
                    "batch_size_liters",
                    "bottles_produced",
                    "selling_price_per_bottle",
                    "items"
                ],
                "properties": {
                    "batch_number": {
                        "type": "string",
                        "example": "BATCH-2026-0001"
                    },
                    "production_date": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-03-07"
                    },
                    "batch_size_liters": {
                        "type": "number",
                        "format": "float",
                        "example": 50
                    },
                    "bottles_produced": {
                        "type": "integer",
                        "example": 100
                    },
                    "selling_price_per_bottle": {
                        "type": "number",
                        "format": "float",
                        "example": 500
                    },
                    "status": {
                        "type": "string",
                        "example": "completed"
                    },
                    "notes": {
                        "type": "string",
                        "example": "Morning fermented milk production"
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ProductionBatchItemRequest"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "Opaque Token",
                "scheme": "bearer"
            }
        }
    },
