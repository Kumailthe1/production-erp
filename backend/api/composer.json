{
  "name": "amsal/fermented-milk-api",
  "description": "Backend API and OpenAPI tooling for the Amsal fermented milk inventory system.",
  "type": "project",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "doctrine/annotations": "^2.0",
    "zircote/swagger-php": "^4.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "docs:clean": "php scripts/clean-openapi.php",
    "docs:generate": "php scripts/generate-openapi.php",
    "docs:build": [
      "@docs:clean",
      "@docs:generate"
    ]
  }
}
